# Discord bot token (https://discord.com/developers/applications)
BOT_TOKEN=your_discord_bot_token_here

# Spotify (https://developer.spotify.com/dashboard)
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here

# Lavalink — required for music on Render (free public nodes: https://lavalink.darrennathanael.com/)
LAVALINK_HOST=lavalink.lexnet.cc
LAVALINK_PORT=443
LAVALINK_PASSWORD=your_lavalink_password_here
LAVALINK_SECURE=true

# HTTP keep-alive port (Render sets PORT automatically)
PORT=3000
